#!/usr/bin/env bash
# theme — aplica una imagen como wallpaper + paleta a todo el desktop.
# Estado centralizado: ~/.config/theme/
# Uso: theme <ruta-imagen>

set -euo pipefail

IMG="${1:-}"
if [[ -z "$IMG" || ! -f "$IMG" ]]; then
    echo "uso: theme <ruta-imagen>" >&2
    echo "     ej:  theme ~/Downloads/foo.jpg" >&2
    exit 1
fi
IMG=$(realpath "$IMG")

if ! command -v matugen >/dev/null 2>&1; then
    echo "error: matugen no está instalado." >&2
    echo "       sudo pacman -S matugen" >&2
    exit 2
fi

WALLDIR="$HOME/Pictures/Wallpapers"
THEMEDIR="$HOME/.config/theme"
mkdir -p "$WALLDIR" "$THEMEDIR/outputs"

SCHEME="${THEME_SCHEME:-scheme-content}"   # scheme-content usa múltiples
                                           # colores de la imagen para acentos,
                                           # no solo un dominante.
PREFER="${THEME_PREFER:-saturation}"       # cuando matugen encuentra varios
                                           # candidatos, elige automáticamente
                                           # el más saturado (= color más
                                           # temáticamente distintivo).
                                           # valores: darkness | lightness |
                                           # saturation | less-saturation |
                                           # value | closest-to-fallback

# 1) copiar imagen al almacén canónico (idempotente).
# Si IMG ya vive dentro de WALLDIR no se copia (sería el mismo archivo).
DEST="$WALLDIR/$(basename "$IMG")"
if [[ "$IMG" != "$DEST" ]]; then
    cp -u "$IMG" "$DEST"
fi

# 2) matugen: genera outputs + lanza post_hooks (waybar/mako reload)
matugen image -t "$SCHEME" --prefer "$PREFER" --mode dark "$DEST"

# 3) renderizar tema oh-my-posh (si el template existe) extrayendo hex del
#    waybar-colors.css que matugen acaba de generar. Esto desacopla oh-my-posh
#    del engine de matugen (que choca con las expresiones {{ }} de oh-my-posh).
OMP_TEMPLATE="$THEMEDIR/atomic.omp.template.json"
OMP_OUTPUT="$THEMEDIR/outputs/oh-my-posh.json"
if [[ -f "$OMP_TEMPLATE" ]]; then
    WCSS="$THEMEDIR/outputs/waybar-colors.css"
    get_hex() { awk -v k="$1" '$2 == k { gsub(";","",$3); print $3 }' "$WCSS"; }
    sed \
        -e "s|__PRIMARY__|$(get_hex primary)|g" \
        -e "s|__ON_PRIMARY__|$(get_hex on_primary)|g" \
        -e "s|__SECONDARY__|$(get_hex secondary)|g" \
        -e "s|__ON_SECONDARY__|$(get_hex on_secondary)|g" \
        -e "s|__TERTIARY__|$(get_hex tertiary)|g" \
        -e "s|__ON_TERTIARY__|$(get_hex on_tertiary)|g" \
        -e "s|__ON_SURFACE__|$(get_hex on_surface)|g" \
        -e "s|__SURFACE_CONTAINER_HIGH__|$(get_hex surface_container_high)|g" \
        -e "s|__SURFACE_CONTAINER_HIGHEST__|$(get_hex surface_container_highest)|g" \
        "$OMP_TEMPLATE" > "$OMP_OUTPUT"
    # El refresco de la shell actual lo hace la función wrapper `theme` del
    # .bashrc (un proceso hijo no puede modificar el prompt de su padre).
    # El binario solo regenera el JSON aquí.
fi

# 4) symlink estable que apunta al wallpaper activo
ln -sfn "$DEST" "$THEMEDIR/current-wallpaper"

# 4b) regenerar hyprpaper.conf con la ruta absoluta resuelta del wallpaper.
# Workaround hyprpaper 0.8.3: preload guarda real-path pero busca wallpaper
# por string literal. El symlink causa lookup miss al boot (renderiza negro
# hasta que se respawnea). Escribir el path real evita el miss.
HYPRPAPER_CONF="$HOME/.config/hypr/hyprpaper.conf"
cat > "$HYPRPAPER_CONF" <<EOF
# AUTO-GENERADO por bin/theme — NO editar a mano.
# Path absoluto resuelto (no symlink) para evitar lookup miss preload/wallpaper
# con hyprpaper 0.8.3.  Regenerado en cada \`theme <img>\`.
preload  = $DEST
wallpaper = ,$DEST
splash   = false
ipc      = on
EOF

# 4) estado del tema
cat > "$THEMEDIR/current.toml" <<EOF
[theme]
wallpaper    = "$DEST"
source_image = "$IMG"
applied_at   = "$(date -Iseconds)"
mode         = "dark"
scheme       = "$SCHEME"
EOF

# 5) wallpaper vivo vía hyprpaper IPC, con fallback a restart.
# hyprpaper 0.8.3 + hyprland 0.54.3 tienen IPC incompatible
# ("hyprpaper protocol version too low") — el IPC siempre falla en silencio.
# Si falla, matar y relanzar hyprpaper: re-lee hyprpaper.conf que apunta al
# symlink current-wallpaper, así carga el wallpaper nuevo.
if pgrep -x hyprpaper >/dev/null; then
    if ! hyprctl hyprpaper wallpaper ",$DEST" >/dev/null 2>&1; then
        pkill -x hyprpaper 2>/dev/null || true
        sleep 0.3
        setsid -f hyprpaper >/dev/null 2>&1 || (setsid hyprpaper >/dev/null 2>&1 &)
    fi
fi

# 5b) regenerar Papirus-Izzy con color de carpeta derivado del primary
if command -v izzy-folders >/dev/null 2>&1; then
    izzy-folders >/dev/null 2>&1 || true
fi

# 6) Hard-restart de waybar (SIGUSR2 solo relee JSON, NO el CSS — gotcha
#    documentado en CLAUDE.md).  Sin restart los colores del @import no
#    se refrescan.
if pgrep -x waybar >/dev/null; then
    pkill waybar 2>/dev/null || true
    setsid -f waybar >/dev/null 2>&1 || (setsid waybar >/dev/null 2>&1 &)
fi

# 7) eww — `reload` NO re-lee `@import url()` (GTK cachea el CSS parseado
#    y el path del symlink `_colors.css` no cambia aunque su contenido sí).
#    Hack: hard-restart del daemon.  Si la ventana estaba abierta, la
#    reabrimos automáticamente para que el cambio sea transparente.
if command -v eww >/dev/null 2>&1 && pgrep -x eww >/dev/null; then
    was_open=$(eww active-windows 2>/dev/null | grep -c dashboard || true)
    eww kill >/dev/null 2>&1 || true
    setsid -f eww daemon >/dev/null 2>&1 || (setsid eww daemon >/dev/null 2>&1 &)
    # pequeño sleep para que el daemon levante el IPC socket
    sleep 0.25
    if [[ "$was_open" == "1" ]]; then
        eww open dashboard >/dev/null 2>&1 || true
    fi
fi

# 8) hyprland reload para tomar los nuevos colores/decoration
if pgrep -x Hyprland >/dev/null; then
    hyprctl reload >/dev/null
fi

notify-send -a theme "Tema aplicado" "$(basename "$DEST")" 2>/dev/null || true
echo "✓ tema: $DEST (scheme=$SCHEME)"
